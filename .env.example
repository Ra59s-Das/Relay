# Google Cloud OAuth 2.0 credentials
# Create these at https://console.cloud.google.com/apis/credentials
# Enable "Google Drive API" and "YouTube Data API v3" on the same project first.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must exactly match an "Authorized redirect URI" on the OAuth client.
# Local dev example: http://localhost:3000/api/auth/callback
# Production example: https://your-domain.com/api/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Default visibility for uploaded videos: private | unlisted | public
DEFAULT_PRIVACY_STATUS=private

# Shared secret so only you (or your cron job) can trigger an automated scan.
# Send it as: /api/scan?auto=1&secret=YOUR_SECRET
SCAN_SECRET=change-me
